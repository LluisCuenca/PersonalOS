<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Personal Track</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.10.0/dist/tabler-icons.min.css"/>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#111111;
  --bg2:#1A1A1A;
  --surface:#1A1A1A;
  --surface2:#242424;
  --surface3:#2E2E2E;
  --grouped:#1A1A1A;
  --border:rgba(255,255,255,0.07);
  --border2:rgba(255,255,255,0.13);
  --text:#FFFFFF;
  --text2:rgba(255,255,255,0.55);
  --text3:rgba(255,255,255,0.28);
  --separator:rgba(255,255,255,0.08);
  --lime:#BAFF39;
  --lime-dim:rgba(186,255,57,0.15);
  --lime-dark:#8FCC1A;
  --accent:#BAFF39;
  --accent2:#BAFF39;
  --accent3:#BAFF39;
  --accent4:#FF5A52;
  --accent5:#AF52DE;
  --accent6:#5AC8FA;
  --radius:12px;
  --radius-lg:16px;
  --radius-xl:22px;
  --radius-xxl:30px;
}

html{-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
body{font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:15px}

/* ── Shell ── */
.shell{display:flex;min-height:100vh}

/* ── Sidebar ── */
.sidebar{
  width:240px;flex-shrink:0;
  background:#0D0D0D;
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;
  position:fixed;top:0;left:0;bottom:0;
  padding:0;z-index:100;
}
.sidebar-header{
  padding:28px 20px 20px;
  border-bottom:1px solid var(--border);
}
.app-logo{display:flex;align-items:center;gap:10px;margin-bottom:4px}
.logo-icon{
  width:34px;height:34px;border-radius:9px;
  background:var(--lime);display:flex;align-items:center;justify-content:center;
  color:#000;font-size:17px;flex-shrink:0;
}
.logo-name{font-size:16px;font-weight:800;letter-spacing:-0.5px;color:var(--text)}
.logo-sub{font-size:11px;color:var(--text3);margin-top:1px;padding-left:44px}

.nav-section{padding:10px 0}
.nav-label{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.1em;padding:8px 20px 4px}
.nav-item{
  display:flex;align-items:center;gap:10px;
  padding:10px 20px;font-size:13px;font-weight:600;
  color:var(--text2);cursor:pointer;border:none;background:none;
  width:100%;text-align:left;transition:all 0.15s;
}
.nav-item i{font-size:17px;width:20px;text-align:center}
.nav-item:hover{color:var(--text);background:var(--surface2)}
.nav-item.active{color:#000;background:var(--lime);border-radius:var(--radius)}
.nav-item.active i{color:#000}

.sidebar-footer{
  margin-top:auto;padding:16px 20px;
  border-top:1px solid var(--border);
}
.tdee-badge{
  background:var(--lime-dim);border:1px solid rgba(186,255,57,0.2);
  border-radius:var(--radius);padding:12px 14px;
}
.tdee-label{font-size:10px;font-weight:700;color:var(--lime);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:3px}
.tdee-val{font-size:24px;font-weight:800;color:var(--text);letter-spacing:-1px}
.tdee-sub{font-size:11px;color:var(--text3);margin-top:2px}

/* ── Main ── */
.main{margin-left:240px;flex:1;padding:36px 36px 60px;max-width:1080px}

/* ── Panels ── */
.panel{display:none;animation:fadeIn 0.2s ease}
.panel.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}}

/* ── Page title ── */
.page-hd{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:28px;gap:16px;flex-wrap:wrap}
.page-title{font-size:32px;font-weight:800;letter-spacing:-1.2px;line-height:1}
.page-sub{font-size:13px;color:var(--text3);margin-top:5px;font-weight:500}
.hd-actions{display:flex;gap:8px;align-items:center;flex-shrink:0}

/* ── Day nav ── */
.day-nav{
  display:inline-flex;align-items:center;gap:0;
  background:var(--surface2);border:1px solid var(--border2);
  border-radius:var(--radius-lg);overflow:hidden;
}
.day-nav-btn{
  width:36px;height:36px;border:none;background:none;
  cursor:pointer;color:var(--text2);font-size:17px;
  display:flex;align-items:center;justify-content:center;
  transition:all 0.12s;
}
.day-nav-btn:hover{background:var(--surface3);color:var(--lime)}
.day-nav-label{
  font-size:13px;font-weight:700;min-width:170px;text-align:center;
  padding:0 8px;color:var(--text);letter-spacing:-0.2px;
}

/* ── Buttons ── */
.btn{
  display:inline-flex;align-items:center;gap:6px;
  padding:9px 16px;font-size:13px;font-weight:700;
  font-family:inherit;border-radius:var(--radius);cursor:pointer;
  transition:all 0.15s;border:1px solid var(--border2);
  background:var(--surface2);color:var(--text2);
  letter-spacing:-0.1px;
}
.btn:hover{background:var(--surface3);color:var(--text);border-color:var(--border2)}
.btn:active{transform:scale(0.97)}
.btn-primary{background:var(--lime);color:#000;border-color:var(--lime)}
.btn-primary:hover{background:#cbff5a;border-color:#cbff5a}
.btn-sm{padding:7px 14px;font-size:12px;border-radius:10px}
.btn-danger{background:rgba(255,90,82,0.12);color:#FF5A52;border-color:transparent}

/* ── Cards ── */
.card{background:var(--surface);border-radius:var(--radius-xl);border:1px solid var(--border);overflow:hidden;margin-bottom:16px}
.card-inset{background:var(--grouped);border-radius:var(--radius-xl);border:1px solid var(--border);margin-bottom:16px}

/* ── Goals row ── */
.goals-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:14px}
.goal-card{
  background:var(--surface2);border-radius:var(--radius-xl);
  border:1px solid var(--border);
  padding:18px 20px;
}
.gc-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.gc-icon{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px}
.gc-label{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.1em}
.gc-val{font-size:30px;font-weight:800;letter-spacing:-1.5px;line-height:1;margin-bottom:2px}
.gc-sub{font-size:11px;color:var(--text3);margin-bottom:10px;font-weight:500}
.ring-wrap{position:relative;width:100%;height:3px;background:var(--surface3);border-radius:99px;overflow:hidden}
.ring-fill{position:absolute;left:0;top:0;height:100%;border-radius:99px;transition:width 0.5s cubic-bezier(0.34,1.56,0.64,1)}

/* ── Day summary card ── */
.summary-card{
  background:var(--surface2);border-radius:var(--radius-xl);
  border:1px solid var(--border);padding:20px;margin-bottom:14px;
}
.summary-title{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:16px}
.summary-row{display:flex;justify-content:space-between;align-items:center;gap:8px;flex-wrap:wrap}
.summary-item{text-align:center;flex:1;min-width:70px}
.si-label{font-size:10px;color:var(--text3);font-weight:600;margin-bottom:3px;text-transform:uppercase;letter-spacing:0.06em}
.si-val{font-size:22px;font-weight:800;letter-spacing:-0.8px}
.si-unit{font-size:11px;color:var(--text3);font-weight:500;margin-left:1px}
.summary-divider{width:1px;background:var(--border);height:36px;flex-shrink:0}
.balance-row{
  margin-top:16px;padding-top:16px;border-top:1px solid var(--border);
  display:flex;align-items:center;gap:12px;
}
.balance-label{font-size:13px;color:var(--text2);flex:1;font-weight:500}
.balance-chip{
  display:inline-flex;align-items:center;gap:5px;
  padding:7px 16px;border-radius:99px;font-size:13px;font-weight:800;
  letter-spacing:-0.2px;
}
.chip-good{background:rgba(186,255,57,0.15);color:var(--lime)}
.chip-warn{background:rgba(255,149,0,0.15);color:#FF9500}
.chip-over{background:rgba(255,90,82,0.15);color:#FF5A52}
.chip-low{background:var(--lime-dim);color:var(--lime)}
.tdee-info{font-size:11px;color:var(--text3);margin-top:4px;font-weight:500}

/* ── Section head ── */
.sec-hd{display:flex;align-items:center;justify-content:space-between;padding:0 2px;margin-bottom:10px}
.sec-title{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.1em}

/* ── Entry list ── */
.entry-list{display:flex;flex-direction:column;gap:0;border-radius:var(--radius-xl);overflow:hidden;border:1px solid var(--border)}
.entry{
  display:flex;align-items:center;gap:12px;
  padding:13px 16px;background:var(--surface2);
  border-bottom:1px solid var(--border);
  transition:background 0.1s;
}
.entry:last-child{border-bottom:none}
.entry:hover{background:var(--surface3)}
.e-icon{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.e-body{flex:1;min-width:0}
.e-name{font-size:14px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.e-meta{font-size:11px;color:var(--text3);margin-top:2px;font-weight:500}
.e-right{text-align:right;flex-shrink:0}
.e-kcal{font-size:15px;font-weight:800;letter-spacing:-0.4px}
.e-prot{font-size:11px;color:var(--text3);margin-top:1px;font-weight:500}
.e-del{
  background:none;border:none;color:var(--text3);cursor:pointer;
  width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;
  font-size:17px;flex-shrink:0;transition:all 0.15s;
}
.e-del:hover{background:rgba(255,90,82,0.15);color:#FF5A52}
.empty-state{
  text-align:center;padding:36px 16px;
  color:var(--text3);font-size:13px;font-weight:500;
  background:var(--surface2);border-radius:var(--radius-xl);
  border:1px dashed var(--border2);
}
.empty-state i{font-size:28px;display:block;margin-bottom:10px;opacity:0.3}

/* ── Library ── */
.lib-controls{display:flex;gap:10px;margin-bottom:14px;flex-wrap:wrap;align-items:center}
.search-wrap{position:relative;flex:1;min-width:180px}
.search-wrap i{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:16px;pointer-events:none}
.search-input{
  width:100%;padding:10px 12px 10px 34px;
  font-family:inherit;font-size:13px;font-weight:500;
  border:1px solid var(--border2);border-radius:var(--radius);
  background:var(--surface2);color:var(--text);outline:none;transition:border-color 0.15s;
}
.search-input:focus{border-color:var(--lime)}
.filter-row{display:flex;gap:6px;flex-wrap:wrap}
.filter-pill{
  padding:6px 14px;font-size:11px;font-weight:700;
  border:1px solid var(--border2);border-radius:99px;
  background:var(--surface2);color:var(--text2);cursor:pointer;transition:all 0.15s;
  text-transform:uppercase;letter-spacing:0.05em;
}
.filter-pill:hover{background:var(--surface3);color:var(--text)}
.filter-pill.active{background:var(--lime);color:#000;border-color:var(--lime)}
.lib-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:10px}
.lib-card{
  background:var(--surface2);border:1px solid var(--border);
  border-radius:var(--radius-xl);padding:16px;
  transition:all 0.18s;cursor:default;
}
.lib-card:hover{border-color:var(--lime);transform:translateY(-2px)}
.lib-tag{
  display:inline-block;font-size:9px;font-weight:800;
  padding:3px 9px;border-radius:99px;margin-bottom:8px;letter-spacing:0.06em;text-transform:uppercase;
}
.lc-name{font-size:14px;font-weight:800;margin-bottom:4px;line-height:1.25}
.lc-macro{font-size:12px;color:var(--text2);font-variant-numeric:tabular-nums;font-weight:500}
.lc-notes{font-size:11px;color:var(--text3);margin-top:6px;font-weight:500}
.lc-actions{display:flex;gap:6px;margin-top:12px;padding-top:12px;border-top:1px solid var(--border)}
.lc-add{
  flex:1;padding:7px;font-size:11px;font-weight:800;
  background:var(--lime-dim);color:var(--lime);
  border:none;border-radius:8px;cursor:pointer;transition:all 0.15s;
  display:flex;align-items:center;justify-content:center;gap:4px;
  text-transform:uppercase;letter-spacing:0.04em;
}
.lc-add:hover{background:var(--lime);color:#000}
.lc-del{
  width:30px;height:30px;border:1px solid var(--border2);border-radius:8px;
  background:none;cursor:pointer;color:var(--text3);font-size:14px;
  display:flex;align-items:center;justify-content:center;transition:all 0.15s;
}
.lc-del:hover{background:rgba(255,90,82,0.15);color:#FF5A52;border-color:#FF5A52}

/* ── Profile ── */
.profile-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px}
.pf-card{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-xl);padding:18px 20px}
.pf-label{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:10px}
.pf-row{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border)}
.pf-row:last-child{border-bottom:none}
.pf-row-label{font-size:13px;color:var(--text2);font-weight:500}
.pf-row-val{font-size:13px;font-weight:700}
.pf-result{
  grid-column:1/-1;
  background:var(--lime-dim);
  border:1px solid rgba(186,255,57,0.2);
  border-radius:var(--radius-xl);padding:22px;
  display:flex;gap:20px;flex-wrap:wrap;
}
.pf-res-item{flex:1;min-width:120px;text-align:center}
.pf-res-num{font-size:32px;font-weight:800;letter-spacing:-1.5px;color:var(--lime)}
.pf-res-label{font-size:11px;color:var(--text2);margin-top:3px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em}

/* ── Historial tabs ── */
.h-tabs{display:flex;gap:0;background:var(--surface2);border-radius:var(--radius);padding:3px;width:fit-content;border:1px solid var(--border)}
.h-tab{padding:6px 18px;font-size:12px;font-weight:700;border:none;background:none;cursor:pointer;color:var(--text3);border-radius:9px;transition:all 0.15s;text-transform:uppercase;letter-spacing:0.05em}
.h-tab.active{background:var(--lime);color:#000}

/* ── Calendar ── */
.cal-card{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-xl);padding:22px;margin-bottom:14px}
.cal-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.cal-month-label{font-size:18px;font-weight:800;letter-spacing:-0.5px}
.cal-nav-btn{width:32px;height:32px;border:none;background:var(--surface3);border-radius:8px;cursor:pointer;color:var(--text2);font-size:16px;display:flex;align-items:center;justify-content:center;transition:all 0.12s}
.cal-nav-btn:hover{background:var(--lime);color:#000}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:3px}
.cal-dow{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.08em;text-align:center;padding:0 0 10px}
.cal-day{
  aspect-ratio:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  border-radius:10px;cursor:pointer;border:1px solid transparent;
  transition:all 0.12s;position:relative;min-height:38px;
}
.cal-day:hover{background:var(--surface3)}
.cal-day.other-month .cd-num{opacity:0.2}
.cal-day.today{background:var(--lime-dim);border-color:rgba(186,255,57,0.3)}
.cal-day.today .cd-num{color:var(--lime);font-weight:800}
.cal-day.selected{background:var(--lime) !important;border-color:var(--lime) !important}
.cal-day.selected .cd-num{color:#000 !important;font-weight:800}
.cal-day.selected .cd-dot{background:#000 !important;opacity:0.5}
.cal-day.has-data .cd-dot{display:block}
.cd-num{font-size:13px;font-weight:600;line-height:1;color:var(--text)}
.cd-dot{display:none;width:4px;height:4px;border-radius:50%;background:var(--lime);margin-top:3px}
.cd-mini{font-size:8px;color:var(--text3);margin-top:1px;font-weight:600}

/* ── Detail pane ── */
.detail-pane{display:flex;gap:14px;align-items:flex-start;flex-wrap:wrap}
.detail-left{flex:1;min-width:260px}
.detail-right{width:280px;flex-shrink:0}
@media(max-width:860px){.detail-right{width:100%}}

.detail-header{
  background:var(--surface2);border:1px solid var(--border);
  border-radius:var(--radius-xl);padding:18px 20px;margin-bottom:10px;
}
.dh-date{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:12px}
.dh-macros{display:flex;gap:0;border-radius:var(--radius-lg);overflow:hidden;border:1px solid var(--border)}
.dh-macro{flex:1;padding:13px 10px;text-align:center;background:var(--surface3)}
.dh-macro+.dh-macro{border-left:1px solid var(--border)}
.dm-val{font-size:20px;font-weight:800;letter-spacing:-0.8px}
.dm-lbl{font-size:9px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.08em;margin-top:3px}

.detail-section{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-xl);margin-bottom:10px;overflow:hidden}
.ds-head{padding:12px 16px;font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.1em;border-bottom:1px solid var(--border)}
.ds-empty{padding:18px;text-align:center;font-size:13px;color:var(--text3);font-weight:500}
.ds-entry{display:flex;align-items:center;gap:10px;padding:11px 14px;border-bottom:1px solid var(--border)}
.ds-entry:last-child{border-bottom:none}
.dse-icon{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.dse-name{flex:1;font-size:13px;font-weight:700}
.dse-meta{font-size:11px;color:var(--text3);font-weight:500}
.dse-kcal{font-size:13px;font-weight:800;color:var(--text2)}

/* ── Week/month view ── */
.period-view{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-xl);padding:20px;margin-bottom:14px}
.pv-title{font-size:14px;font-weight:800;margin-bottom:3px;letter-spacing:-0.3px}
.pv-sub{font-size:11px;color:var(--text3);margin-bottom:16px;font-weight:500}
.chart-wrap{position:relative;height:200px}

.stats-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:16px}
.stat-card{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-xl);padding:20px}
.stat-lbl{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:8px}
.stat-num{font-size:32px;font-weight:800;letter-spacing:-2px;line-height:1}
.stat-unit{font-size:13px;color:var(--text3);margin-left:3px;font-weight:500;letter-spacing:0}

/* ── Week bar mini ── */
.week-bar-row{display:grid;grid-template-columns:repeat(7,1fr);gap:8px;margin-bottom:14px}
.wb-day{background:var(--surface2);border-radius:var(--radius);padding:8px 4px;text-align:center;cursor:pointer;border:1px solid var(--border);transition:all 0.12s}
.wb-day:hover{border-color:var(--lime)}
.wb-day.sel{border-color:var(--lime);background:var(--lime-dim)}
.wb-day.has .wb-dot{background:var(--lime)}
.wb-n{font-size:10px;color:var(--text3);font-weight:700;text-transform:uppercase;letter-spacing:0.06em}
.wb-d{font-size:15px;font-weight:800;margin:2px 0;letter-spacing:-0.3px}
.wb-dot{width:5px;height:5px;border-radius:50%;background:var(--surface3);margin:0 auto}

/* ── Modals ── */
.overlay{
  position:fixed;inset:0;background:rgba(0,0,0,0.7);
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
  display:flex;align-items:center;justify-content:center;
  z-index:1000;padding:20px;
}
.modal{
  background:#1A1A1A;border-radius:var(--radius-xxl);
  border:1px solid var(--border2);padding:26px;
  width:100%;max-width:440px;max-height:88vh;overflow-y:auto;
  box-shadow:0 32px 64px rgba(0,0,0,0.6),0 4px 12px rgba(0,0,0,0.3);
  animation:modalPop 0.22s cubic-bezier(0.34,1.56,0.64,1);
}
.modal-wide{max-width:520px}
@keyframes modalPop{from{transform:scale(0.92) translateY(12px);opacity:0}}
.modal-title{font-size:20px;font-weight:800;letter-spacing:-0.8px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--border)}
.modal-footer{display:flex;gap:8px;justify-content:flex-end;margin-top:20px;padding-top:16px;border-top:1px solid var(--border)}

.fg{margin-bottom:14px}
.fl{display:block;font-size:10px;font-weight:700;color:var(--text3);margin-bottom:5px;text-transform:uppercase;letter-spacing:0.08em}
.fi,.fs,.ft{
  width:100%;padding:11px 13px;font-family:inherit;font-size:14px;font-weight:500;
  border:1px solid var(--border2);border-radius:var(--radius);
  background:var(--surface3);color:var(--text);outline:none;transition:border-color 0.15s;
}
.fi:focus,.fs:focus,.ft:focus{border-color:var(--lime);background:#222}
.ft{height:70px;resize:vertical}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.fcheck{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text2);cursor:pointer;padding:6px 0;font-weight:500}
.fcheck input{width:16px;height:16px;accent-color:var(--lime);cursor:pointer}

.act-icons{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}
.act-ico{
  padding:8px 10px;border:1px solid var(--border2);
  border-radius:var(--radius);cursor:pointer;
  background:var(--surface2);transition:all 0.15s;
  display:flex;flex-direction:column;align-items:center;gap:3px;
}
.act-ico span{font-size:20px}
.act-ico small{font-size:9px;color:var(--text3);font-weight:700;text-transform:uppercase;letter-spacing:0.04em}
.act-ico:hover{border-color:var(--lime);background:var(--lime-dim)}
.act-ico.sel{background:var(--lime-dim);border-color:var(--lime)}

.libpick-item{
  display:flex;align-items:center;gap:10px;
  padding:11px 13px;border:1px solid var(--border);
  border-radius:var(--radius);cursor:pointer;
  transition:all 0.15s;background:var(--surface2);
}
.libpick-item+.libpick-item{margin-top:6px}
.libpick-item:hover{border-color:var(--lime);background:var(--lime-dim)}

/* ── Responsive ── */
@media(max-width:720px){
  .sidebar{width:0;display:none}
  .main{margin-left:0;padding:16px 12px 60px}
  .goals-grid{grid-template-columns:1fr 1fr}
  .stats-grid{grid-template-columns:1fr}
  .profile-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>
<div class="shell">

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sidebar-header">
    <div class="app-logo">
      <div class="logo-icon"><i class="ti ti-activity-heartbeat" style="font-size:20px"></i></div>
      <span class="logo-name">Personal Track</span>
    </div>
    <div class="logo-sub" id="sb-user">Mi perfil</div>
  </div>
  <div class="nav-section">
    <div class="nav-label">Seguimiento</div>
    <button class="nav-item active" onclick="goTab('today')"><i class="ti ti-calendar-today"></i> Hoy</button>
    <button class="nav-item" onclick="goTab('stats')"><i class="ti ti-chart-area-line"></i> Progreso</button>
  </div>
  <div class="nav-section">
    <div class="nav-label">Gestión</div>
    <button class="nav-item" onclick="goTab('library')"><i class="ti ti-bookmark"></i> Biblioteca</button>
    <button class="nav-item" onclick="goTab('profile')"><i class="ti ti-user-circle"></i> Perfil físico</button>
  </div>
  <div class="sidebar-footer">
    <div class="tdee-badge">
      <div class="tdee-label">TDEE estimado</div>
      <div class="tdee-val" id="sb-tdee">—</div>
      <div class="tdee-sub">kcal/día objetivo</div>
    </div>
  </div>
</aside>

<!-- MAIN -->
<main class="main">

<!-- TODAY -->
<div id="tab-today" class="panel active">
  <div class="page-hd">
    <div class="day-nav">
      <button class="day-nav-btn" onclick="changeDay(-1)"><i class="ti ti-chevron-left"></i></button>
      <span class="day-nav-label" id="day-label">Hoy</span>
      <button class="day-nav-btn" onclick="changeDay(1)"><i class="ti ti-chevron-right"></i></button>
    </div>
    <div class="hd-actions">
      <button class="btn btn-sm" onclick="openLibPicker()"><i class="ti ti-bookmark"></i> Biblioteca</button>
      <button class="btn btn-sm" onclick="openAddActivity()"><i class="ti ti-run"></i> Actividad</button>
      <button class="btn btn-sm btn-primary" onclick="openAddFood()"><i class="ti ti-plus"></i> Alimento</button>
    </div>
  </div>

  <!-- GOAL CARDS -->
  <div class="goals-grid">
    <div class="goal-card">
      <div class="gc-top">
        <span class="gc-label">Calorías</span>
        <div class="gc-icon" style="background:rgba(255,59,48,0.12)">🔥</div>
      </div>
      <div class="gc-val" id="gc-cal">0</div>
      <div class="gc-sub" id="gc-cal-sub">/ — kcal</div>
      <div class="ring-wrap"><div class="ring-fill" id="rf-cal" style="width:0%;background:#FF5A52"></div></div>
    </div>
    <div class="goal-card">
      <div class="gc-top">
        <span class="gc-label">Proteína</span>
        <div class="gc-icon" style="background:rgba(0,122,255,0.12)">💪</div>
      </div>
      <div class="gc-val" id="gc-prot">0g</div>
      <div class="gc-sub" id="gc-prot-sub">/ — g</div>
      <div class="ring-wrap"><div class="ring-fill" id="rf-prot" style="width:0%;background:var(--accent)"></div></div>
    </div>
    <div class="goal-card">
      <div class="gc-top">
        <span class="gc-label">Actividad</span>
        <div class="gc-icon" style="background:rgba(255,149,0,0.12)">⚡</div>
      </div>
      <div class="gc-val" id="gc-act">0</div>
      <div class="gc-sub">kcal quemadas</div>
      <div class="ring-wrap"><div class="ring-fill" id="rf-act" style="width:0%;background:var(--accent3)"></div></div>
    </div>
  </div>

  <!-- DAY SUMMARY -->
  <div class="summary-card">
    <div class="summary-title">Resumen del día</div>
    <div class="summary-row">
      <div class="summary-item">
        <div class="si-label">Ingerido</div>
        <div class="si-val" id="sm-in">0<span class="si-unit">kcal</span></div>
      </div>
      <div class="summary-divider"></div>
      <div class="summary-item">
        <div class="si-label">TMB basal</div>
        <div class="si-val" id="sm-bmr">—<span class="si-unit">kcal</span></div>
      </div>
      <div class="summary-divider"></div>
      <div class="summary-item">
        <div class="si-label">Actividad</div>
        <div class="si-val" id="sm-act">0<span class="si-unit">kcal</span></div>
      </div>
      <div class="summary-divider"></div>
      <div class="summary-item">
        <div class="si-label">TDEE hoy</div>
        <div class="si-val" id="sm-tdee">—<span class="si-unit">kcal</span></div>
      </div>
    </div>
    <div class="balance-row">
      <div>
        <div class="balance-label">Balance neto</div>
        <div class="tdee-info" id="sm-info">Configura tu perfil para ver el balance personalizado</div>
      </div>
      <div class="balance-chip chip-low" id="sm-chip">— kcal</div>
    </div>
  </div>

  <!-- FOODS -->
  <div class="sec-hd" style="margin-bottom:10px">
    <span class="sec-title">Comidas</span>
  </div>
  <div style="margin-bottom:16px">
    <div class="entry-list" id="food-list"></div>
  </div>

  <!-- ACTIVITIES -->
  <div class="sec-hd" style="margin-bottom:10px">
    <span class="sec-title">Actividad física</span>
  </div>
  <div class="entry-list" id="act-list"></div>
</div>

<!-- HISTORIAL Y PROGRESO -->
<div id="tab-stats" class="panel">
  <div class="page-hd">
    <div>
      <div class="page-title">Historial y Progreso</div>
      <div class="page-sub">Calendario, detalle diario y evolución</div>
    </div>
    <div style="display:flex;gap:8px;align-items:center">
      <div class="h-tabs" id="h-tabs">
        <button class="h-tab active" onclick="setHistTab('day',this)">Diario</button>
        <button class="h-tab" onclick="setHistTab('week',this)">Semanal</button>
        <button class="h-tab" onclick="setHistTab('month',this)">Mensual</button>
      </div>
      <button class="btn btn-sm" onclick="exportData()"><i class="ti ti-download"></i></button>
    </div>
  </div>

  <!-- CALENDAR -->
  <div class="cal-card">
    <div class="cal-nav">
      <button class="cal-nav-btn" onclick="calPrev()"><i class="ti ti-chevron-left"></i></button>
      <span class="cal-month-label" id="cal-month-label"></span>
      <button class="cal-nav-btn" onclick="calNext()"><i class="ti ti-chevron-right"></i></button>
    </div>
    <div class="cal-grid" id="cal-grid"></div>
  </div>

  <!-- DAY VIEW -->
  <div id="hist-day" class="hist-view">
    <div style="font-size:13px;font-weight:600;color:var(--text2);margin-bottom:10px;text-transform:uppercase;letter-spacing:0.06em" id="detail-date-label">Selecciona un día en el calendario</div>
    <div class="detail-pane" id="detail-pane">
      <div style="flex:1;color:var(--text3);font-size:14px;text-align:center;padding:32px 0">
        <i class="ti ti-calendar-event" style="font-size:28px;display:block;margin-bottom:8px;opacity:0.3"></i>
        Haz click en un día para ver su detalle
      </div>
    </div>
  </div>

  <!-- WEEK VIEW -->
  <div id="hist-week" class="hist-view" style="display:none">
    <div class="week-bar-row" id="week-bar-row"></div>
    <div class="period-view">
      <div class="pv-title">Calorías — últimos 7 días</div>
      <div class="pv-sub" id="week-cal-sub">vs objetivo</div>
      <div class="chart-wrap"><canvas id="chart-cal"></canvas></div>
    </div>
    <div class="period-view">
      <div class="pv-title">Proteína — últimos 7 días</div>
      <div class="pv-sub">gramos/día</div>
      <div class="chart-wrap"><canvas id="chart-prot"></canvas></div>
    </div>
    <div class="stats-grid">
      <div class="stat-card"><div class="stat-lbl">Prom. calorías</div><div class="stat-num" id="avg-cal">—<span class="stat-unit">kcal</span></div></div>
      <div class="stat-card"><div class="stat-lbl">Prom. proteína</div><div class="stat-num" id="avg-prot">—<span class="stat-unit">g</span></div></div>
      <div class="stat-card"><div class="stat-lbl">Días registrados</div><div class="stat-num" id="days-count">0</div></div>
      <div class="stat-card"><div class="stat-lbl">Actividad semana</div><div class="stat-num" id="total-act">0<span class="stat-unit">kcal</span></div></div>
    </div>
  </div>

  <!-- MONTH VIEW -->
  <div id="hist-month" class="hist-view" style="display:none">
    <div class="period-view">
      <div class="pv-title">Calorías — este mes</div>
      <div class="pv-sub" id="month-cal-sub">vs objetivo</div>
      <div class="chart-wrap"><canvas id="chart-cal-month"></canvas></div>
    </div>
    <div class="period-view">
      <div class="pv-title">Proteína — este mes</div>
      <div class="pv-sub">gramos/día</div>
      <div class="chart-wrap"><canvas id="chart-prot-month"></canvas></div>
    </div>
    <div class="stats-grid">
      <div class="stat-card"><div class="stat-lbl">Prom. calorías mes</div><div class="stat-num" id="mavg-cal">—<span class="stat-unit">kcal</span></div></div>
      <div class="stat-card"><div class="stat-lbl">Prom. proteína mes</div><div class="stat-num" id="mavg-prot">—<span class="stat-unit">g</span></div></div>
      <div class="stat-card"><div class="stat-lbl">Días con datos</div><div class="stat-num" id="mdays">0</div></div>
      <div class="stat-card"><div class="stat-lbl">Actividad mes</div><div class="stat-num" id="mact">0<span class="stat-unit">kcal</span></div></div>
    </div>
  </div>
</div>

<!-- LIBRARY -->
<div id="tab-library" class="panel">
  <div class="page-hd">
    <div>
      <div class="page-title">Biblioteca</div>
      <div class="page-sub">Alimentos, recetas y combinaciones</div>
    </div>
    <button class="btn btn-primary btn-sm" onclick="openAddLib()"><i class="ti ti-plus"></i> Nuevo</button>
  </div>
  <div class="lib-controls">
    <div class="search-wrap">
      <i class="ti ti-search"></i>
      <input class="search-input" type="text" placeholder="Buscar..." oninput="filterLib(this.value)"/>
    </div>
    <div class="filter-row" id="lib-filters"></div>
  </div>
  <div class="lib-grid" id="lib-grid"></div>
</div>

<!-- PROFILE -->
<div id="tab-profile" class="panel">
  <div class="page-hd">
    <div>
      <div class="page-title">Perfil físico</div>
      <div class="page-sub">Tus datos para calcular TDEE y objetivos personalizados</div>
    </div>
    <button class="btn btn-primary btn-sm" onclick="openEditProfile()"><i class="ti ti-edit"></i> Editar</button>
  </div>

  <div class="profile-grid">
    <div class="pf-card">
      <div class="pf-label">Datos físicos</div>
      <div class="pf-row"><span class="pf-row-label">Sexo</span><span class="pf-row-val" id="pf-sex">—</span></div>
      <div class="pf-row"><span class="pf-row-label">Edad</span><span class="pf-row-val" id="pf-age">—</span></div>
      <div class="pf-row"><span class="pf-row-label">Peso</span><span class="pf-row-val" id="pf-weight">—</span></div>
      <div class="pf-row"><span class="pf-row-label">Altura</span><span class="pf-row-val" id="pf-height">—</span></div>
    </div>
    <div class="pf-card">
      <div class="pf-label">Objetivos</div>
      <div class="pf-row"><span class="pf-row-label">Actividad basal</span><span class="pf-row-val" id="pf-activity">—</span></div>
      <div class="pf-row"><span class="pf-row-label">Meta calórica</span><span class="pf-row-val" id="pf-goal">—</span></div>
      <div class="pf-row"><span class="pf-row-label">Meta proteína</span><span class="pf-row-val" id="pf-prot">—</span></div>
      <div class="pf-row"><span class="pf-row-label">Objetivo</span><span class="pf-row-val" id="pf-target">—</span></div>
    </div>
    <div class="pf-result" id="pf-result">
      <div class="pf-res-item"><div class="pf-res-num" id="pfr-bmr">—</div><div class="pf-res-label">TMB (Basal)</div></div>
      <div class="pf-res-item"><div class="pf-res-num" id="pfr-tdee">—</div><div class="pf-res-label">TDEE (con actividad)</div></div>
      <div class="pf-res-item"><div class="pf-res-num" id="pfr-target">—</div><div class="pf-res-label">Objetivo diario</div></div>
      <div class="pf-res-item"><div class="pf-res-num" id="pfr-prot">—</div><div class="pf-res-label">Proteína objetivo (g)</div></div>
    </div>
  </div>
</div>

</main>
</div>

<!-- MODAL: Add food -->
<div id="modal-food" class="overlay" style="display:none" onclick="closeOv(event,'modal-food')">
<div class="modal" onclick="event.stopPropagation()">
  <div class="modal-title" id="food-modal-title">Añadir alimento</div>
  <div class="fg"><label class="fl">Nombre</label><input id="f-name" class="fi" type="text" placeholder="Ej: Pollo a la plancha" autocomplete="off"/></div>
  <div class="fg2">
    <div class="fg"><label class="fl">Calorías (kcal)</label><input id="f-cal" class="fi" type="number" min="0" placeholder="0"/></div>
    <div class="fg"><label class="fl">Proteína (g)</label><input id="f-prot" class="fi" type="number" min="0" placeholder="0"/></div>
    <div class="fg"><label class="fl">Carbos (g)</label><input id="f-carb" class="fi" type="number" min="0" placeholder="0"/></div>
    <div class="fg"><label class="fl">Grasa (g)</label><input id="f-fat" class="fi" type="number" min="0" placeholder="0"/></div>
  </div>
  <div class="fg"><label class="fl">Cantidad / notas</label><input id="f-qty" class="fi" type="text" placeholder="200g, 1 porción..."/></div>
  <div class="fg"><label class="fl">Comida</label>
    <select id="f-cat" class="fs"><option>Desayuno</option><option>Almuerzo</option><option>Cena</option><option>Snack</option><option>Suplemento</option></select>
  </div>
  <label class="fcheck"><input type="checkbox" id="f-save"/> Guardar en biblioteca</label>
  <div class="modal-footer">
    <button class="btn" onclick="closeId('modal-food')">Cancelar</button>
    <button class="btn btn-primary" onclick="saveFood()"><i class="ti ti-check"></i> Añadir</button>
  </div>
</div>
</div>

<!-- MODAL: Activity -->
<div id="modal-activity" class="overlay" style="display:none" onclick="closeOv(event,'modal-activity')">
<div class="modal" onclick="event.stopPropagation()">
  <div class="modal-title">Añadir actividad</div>
  <div class="act-icons" id="act-icons-render"></div>
  <div class="fg"><label class="fl">Nombre</label><input id="a-name" class="fi" type="text" placeholder="Escalada, Paseo..."/></div>
  <div class="fg2">
    <div class="fg"><label class="fl">Duración (min)</label><input id="a-dur" class="fi" type="number" min="0" placeholder="30"/></div>
    <div class="fg"><label class="fl">Kcal quemadas</label><input id="a-kcal" class="fi" type="number" min="0" placeholder="0"/></div>
  </div>
  <div class="fg"><label class="fl">Intensidad / notas</label><input id="a-notes" class="fi" type="text" placeholder="Media, alta..."/></div>
  <div class="modal-footer">
    <button class="btn" onclick="closeId('modal-activity')">Cancelar</button>
    <button class="btn btn-primary" onclick="saveActivity()"><i class="ti ti-check"></i> Añadir</button>
  </div>
</div>
</div>

<!-- MODAL: Library item -->
<div id="modal-lib" class="overlay" style="display:none" onclick="closeOv(event,'modal-lib')">
<div class="modal" onclick="event.stopPropagation()">
  <div class="modal-title" id="lib-modal-title">Nuevo elemento</div>
  <div class="fg"><label class="fl">Nombre</label><input id="lb-name" class="fi" type="text"/></div>
  <div class="fg2">
    <div class="fg"><label class="fl">Calorías</label><input id="lb-cal" class="fi" type="number" min="0"/></div>
    <div class="fg"><label class="fl">Proteína (g)</label><input id="lb-prot" class="fi" type="number" min="0"/></div>
    <div class="fg"><label class="fl">Carbos (g)</label><input id="lb-carb" class="fi" type="number" min="0"/></div>
    <div class="fg"><label class="fl">Grasa (g)</label><input id="lb-fat" class="fi" type="number" min="0"/></div>
  </div>
  <div class="fg"><label class="fl">Tipo</label>
    <select id="lb-type" class="fs"><option>Alimento</option><option>Receta</option><option>Snack</option><option>Suplemento</option><option>Combinación</option></select>
  </div>
  <div class="fg"><label class="fl">Notas / ingredientes</label><textarea id="lb-notes" class="ft" placeholder="Ingredientes, preparación, cantidad..."></textarea></div>
  <div class="modal-footer">
    <button class="btn" onclick="closeId('modal-lib')">Cancelar</button>
    <button class="btn btn-primary" onclick="saveToLib()"><i class="ti ti-check"></i> Guardar</button>
  </div>
</div>
</div>

<!-- MODAL: Profile edit -->
<div id="modal-profile" class="overlay" style="display:none" onclick="closeOv(event,'modal-profile')">
<div class="modal modal-wide" onclick="event.stopPropagation()">
  <div class="modal-title">Perfil físico</div>
  <div class="fg2">
    <div class="fg"><label class="fl">Sexo</label>
      <select id="p-sex" class="fs"><option value="m">Hombre</option><option value="f">Mujer</option></select>
    </div>
    <div class="fg"><label class="fl">Edad (años)</label><input id="p-age" class="fi" type="number" min="10" max="99"/></div>
    <div class="fg"><label class="fl">Peso (kg)</label><input id="p-weight" class="fi" type="number" min="30" step="0.1"/></div>
    <div class="fg"><label class="fl">Altura (cm)</label><input id="p-height" class="fi" type="number" min="100" max="250"/></div>
  </div>
  <div class="fg"><label class="fl">Nivel de actividad diaria</label>
    <select id="p-activity" class="fs">
      <option value="1.2">Sedentario (poco o ningún ejercicio)</option>
      <option value="1.375">Ligeramente activo (1–3 días/semana)</option>
      <option value="1.55" selected>Moderadamente activo (3–5 días/semana)</option>
      <option value="1.725">Muy activo (6–7 días/semana)</option>
      <option value="1.9">Extremadamente activo (trabajo físico + deporte)</option>
    </select>
  </div>
  <div class="fg"><label class="fl">Objetivo</label>
    <select id="p-goal-type" class="fs">
      <option value="maintain">Mantener peso</option>
      <option value="lose">Perder peso (−300 kcal)</option>
      <option value="lose_fast">Perder peso rápido (−500 kcal)</option>
      <option value="gain">Ganar masa (+300 kcal)</option>
    </select>
  </div>
  <div class="fg2">
    <div class="fg"><label class="fl">Objetivo calorías (kcal)</label><input id="p-cal" class="fi" type="number" placeholder="Auto (TDEE)"/></div>
    <div class="fg"><label class="fl">Objetivo proteína (g)</label><input id="p-prot" class="fi" type="number" placeholder="Auto (2g/kg)"/></div>
  </div>
  <div class="modal-footer">
    <button class="btn" onclick="closeId('modal-profile')">Cancelar</button>
    <button class="btn btn-primary" onclick="saveProfile()"><i class="ti ti-check"></i> Guardar</button>
  </div>
</div>
</div>

<!-- MODAL: Library picker -->
<div id="modal-libpick" class="overlay" style="display:none" onclick="closeOv(event,'modal-libpick')">
<div class="modal" onclick="event.stopPropagation()">
  <div class="modal-title">Añadir desde biblioteca</div>
  <input class="fi" type="text" placeholder="Buscar..." oninput="renderLibPick(this.value)" style="margin-bottom:12px"/>
