// ─── BMR / TDEE ───
function calcBMR(p){
  if(!p)return null;
  const w=Number(p.weight),h=Number(p.height),a=Number(p.age);
  if(!w||!h||!a)return null;
  return p.sex==='m'
    ? Math.round(88.362 + 13.397*w + 4.799*h - 5.677*a)
    : Math.round(447.593 + 9.247*w + 3.098*h - 4.330*a);
}
function calcTDEE(p){
  const bmr=calcBMR(p);
  if(!bmr)return null;
  return Math.round(bmr*(Number(p.activity)||1.55));
}
function calcGoalCal(p){
  if(!p)return null;
  const tdee=calcTDEE(p);if(!tdee)return null;
  if(p.calOverride&&Number(p.calOverride)>0)return Number(p.calOverride);
  const adj={maintain:0,lose:-300,lose_fast:-500,gain:+300};
  return tdee+(adj[p.goalType]||0);
}
function calcGoalProt(p){
  if(!p)return null;
  if(p.protOverride&&Number(p.protOverride)>0)return Number(p.protOverride);
  return p.weight?Math.round(Number(p.weight)*2):null;
}

