// ─── RENDER DAY ───
function renderDay(){
  const d=S.currentDate,today=todayStr();
  const dt=new Date(d+'T12:00:00');
  const DN=['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
  const MN=['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];
  document.getElementById('day-label').textContent=d===today?'Hoy, '+dt.getDate()+' '+MN[dt.getMonth()]:DN[dt.getDay()]+' '+dt.getDate()+' '+MN[dt.getMonth()];

  const day=getDay(d);
  const totCal=day.foods.reduce((s,f)=>s+Number(f.cal||0),0);
  const totProt=day.foods.reduce((s,f)=>s+Number(f.prot||0),0);
  const totAct=day.activities.reduce((s,a)=>s+Number(a.kcal||0),0);

  const goalCal=calcGoalCal(S.profile)||2000;
  const goalProt=calcGoalProt(S.profile)||150;
  const bmr=calcBMR(S.profile);
  const tdee=calcTDEE(S.profile);

  // goal cards
  document.getElementById('gc-cal').textContent=Math.round(totCal);
  document.getElementById('gc-prot').textContent=Math.round(totProt)+'g';
  document.getElementById('gc-act').textContent=Math.round(totAct);
  document.getElementById('gc-cal-sub').textContent='/ '+goalCal+' kcal';
  document.getElementById('gc-prot-sub').textContent='/ '+goalProt+'g';
  document.getElementById('rf-cal').style.width=Math.min(100,Math.round(totCal/goalCal*100))+'%';
  document.getElementById('rf-prot').style.width=Math.min(100,Math.round(totProt/goalProt*100))+'%';
  document.getElementById('rf-act').style.width=Math.min(100,Math.round(totAct/500*100))+'%';

  // summary
  document.getElementById('sm-in').innerHTML=Math.round(totCal)+'<span class="si-unit">kcal</span>';
  document.getElementById('sm-bmr').innerHTML=(bmr?bmr:'—')+'<span class="si-unit">kcal</span>';
  document.getElementById('sm-act').innerHTML=Math.round(totAct)+'<span class="si-unit">kcal</span>';
  const tdeePlus=tdee?Math.round(tdee+totAct):null;
  document.getElementById('sm-tdee').innerHTML=(tdeePlus?tdeePlus:'—')+'<span class="si-unit">kcal</span>';

  const balance=tdeePlus?Math.round(totCal-tdeePlus):null;
  const chip=document.getElementById('sm-chip');
  const info=document.getElementById('sm-info');
  if(balance===null){
    chip.textContent='— kcal';chip.className='balance-chip chip-low';
    info.textContent='Configura tu perfil físico para ver el balance personalizado';
  } else {
    const abs=Math.abs(balance);
    if(balance<-100){chip.textContent='−'+abs+' kcal';chip.className='balance-chip chip-good';info.textContent='Déficit calórico — buen progreso'}
    else if(balance>100){chip.textContent='+'+abs+' kcal';chip.className='balance-chip chip-over';info.textContent='Superávit — '+abs+' kcal por encima del objetivo'}
    else{chip.textContent=(balance>=0?'+':'')+balance+' kcal';chip.className='balance-chip chip-warn';info.textContent='En equilibrio con el objetivo'}
  }

  // food list
  const fl=document.getElementById('food-list');
  fl.innerHTML=day.foods.length?day.foods.map((f,i)=>`
    <div class="entry">
      <div class="e-icon" style="background:${CAT_BG[f.cat]||'rgba(118,118,128,0.1)'}">${CAT_ICONS[f.cat]||'🍽️'}</div>
      <div class="e-body"><div class="e-name">${esc(f.name)}</div><div class="e-meta">${esc(f.cat||'')}${f.qty?' · '+esc(f.qty):''}</div></div>
      <div class="e-right"><div class="e-kcal">${Math.round(f.cal||0)} kcal</div><div class="e-prot">${Math.round(f.prot||0)}g P${f.carb?' · '+Math.round(f.carb)+'g C':''}</div></div>
      <button class="e-del" onclick="delFood(${i})">×</button>
    </div>`).join('')
    :'<div class="empty-state"><i class="ti ti-salad"></i>Sin alimentos. Pulsa <strong>+ Alimento</strong> o usa la <strong>Biblioteca</strong>.</div>';

  const al=document.getElementById('act-list');
  al.innerHTML=day.activities.length?day.activities.map((a,i)=>`
    <div class="entry">
      <div class="e-icon" style="background:rgba(255,149,0,0.12);font-size:18px">${a.icon||'🏃'}</div>
      <div class="e-body"><div class="e-name">${esc(a.name)}</div><div class="e-meta">${a.dur?a.dur+' min':''}${a.notes?' · '+esc(a.notes):''}</div></div>
      <div class="e-right"><div class="e-kcal" style="color:var(--accent3)">${a.kcal?'−'+Math.round(a.kcal)+' kcal':''}</div></div>
      <button class="e-del" onclick="delAct(${i})">×</button>
    </div>`).join('')
    :'<div class="empty-state" style="padding:20px 16px"><i class="ti ti-run"></i>Sin actividad registrada hoy.</div>';
}

