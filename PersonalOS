function show(id){document.getElementById(id).style.display='flex'}
function closeId(id){document.getElementById(id).style.display='none'}
function closeOv(e,id){if(e.target.id===id)closeId(id)}
document.addEventListener('keydown',e=>{if(e.key==='Escape')document.querySelectorAll('.overlay').forEach(o=>o.style.display='none')});

load();
