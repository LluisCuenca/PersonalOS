// ─── CALENDAR ───
function renderCalendar(){
  const y=calViewDate.getFullYear(),m=calViewDate.getMonth();
  const MONTHS=['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  document.getElementById('cal-month-label').textContent=MONTHS[m]+' '+y;
  const firstDay=new Date(y,m,1).getDay(); // 0=Sun
  const daysInMonth=new Date(y,m+1,0).getDate();
  const daysInPrev=new Date(y,m,0).getDate();
  const today=todayStr();
  const DOW=['L','M','X','J','V','S','D'];
  let html=DOW.map(d=>`<div class="cal-dow">${d}</div>`).join('');
  // offset: week starts Monday
  const offset=(firstDay+6)%7;
  // prev month filler
  for(let i=offset-1;i>=0;i--){
    const day=daysInPrev-i;
    html+=`<div class="cal-day other-month"><span class="cd-num">${day}</span><span class="cd-dot"></span></div>`;
  }
  // current month
  for(let d=1;d<=daysInMonth;d++){
    const ds=y+'-'+String(m+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    const hasData=S.days[ds]&&(S.days[ds].foods.length||S.days[ds].activities.length);
    const isToday=ds===today;
    const isSel=ds===selectedDate;
    const totCal=hasData?Math.round(S.days[ds].foods.reduce((s,f)=>s+Number(f.cal||0),0)):0;
    let cls='cal-day'+(isToday?' today':'')+(isSel?' selected':'')+(hasData?' has-data':'');
    html+=`<div class="${cls}" onclick="selectCalDay('${ds}')">
      <span class="cd-num">${d}</span>
      <span class="cd-dot"></span>
      ${hasData?`<span class="cd-mini">${totCal}</span>`:''}
    </div>`;
  }
  // next month filler
  const total=offset+daysInMonth;
  const remaining=(7-total%7)%7;
  for(let d=1;d<=remaining;d++){
    html+=`<div class="cal-day other-month"><span class="cd-num">${d}</span><span class="cd-dot"></span></div>`;
  }
  document.getElementById('cal-grid').innerHTML=html;
}

function calPrev(){calViewDate=new Date(calViewDate.getFullYear(),calViewDate.getMonth()-1,1);renderCalendar()}
function calNext(){calViewDate=new Date(calViewDate.getFullYear(),calViewDate.getMonth()+1,1);renderCalendar()}

function selectCalDay(ds){
  selectedDate=ds;
  renderCalendar();
  renderDayDetail(ds);
  if(histTab==='week')renderWeekView();
}

// ─── DAY DETAIL ───
function renderDayDetail(ds){
  const dt=new Date(ds+'T12:00:00');
  const DN=['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
  const MN=['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
  document.getElementById('detail-date-label').textContent=DN[dt.getDay()]+', '+dt.getDate()+' de '+MN[dt.getMonth()]+' '+dt.getFullYear();
  const day=S.days[ds];
  const pane=document.getElementById('detail-pane');
  if(!day||(!day.foods.length&&!day.activities.length)){
    pane.innerHTML=`<div style="flex:1;text-align:center;padding:32px;color:var(--text3);font-size:14px"><i class="ti ti-calendar-off" style="font-size:28px;display:block;margin-bottom:8px;opacity:0.3"></i>Sin datos para este día</div>`;
    return;
  }
  const totCal=Math.round(day.foods.reduce((s,f)=>s+Number(f.cal||0),0));
  const totProt=Math.round(day.foods.reduce((s,f)=>s+Number(f.prot||0),0));
  const totCarb=Math.round(day.foods.reduce((s,f)=>s+Number(f.carb||0),0));
  const totFat=Math.round(day.foods.reduce((s,f)=>s+Number(f.fat||0),0));
  const totAct=Math.round(day.activities.reduce((s,a)=>s+Number(a.kcal||0),0));
  const goalCal=calcGoalCal(S.profile)||2000;
  const balance=totCal-(calcTDEE(S.profile)||goalCal)-totAct;
  const balChip=balance<-50?'chip-good':balance>50?'chip-over':'chip-warn';
  const balStr=(balance>=0?'+':'')+balance;

  const CAT_BG2={Desayuno:'rgba(90,200,250,0.12)',Almuerzo:'rgba(52,199,89,0.12)',Cena:'rgba(255,59,48,0.1)',Snack:'rgba(255,149,0,0.12)',Suplemento:'rgba(175,82,222,0.1)'};
  const CAT_ICONS2={Desayuno:'🍳',Almuerzo:'🥗',Cena:'🍽️',Snack:'🍎',Suplemento:'💊'};

  const foodsHtml=day.foods.length?day.foods.map(f=>`
    <div class="ds-entry">
      <div class="dse-icon" style="background:${CAT_BG2[f.cat]||'rgba(118,118,128,0.1)'}">${CAT_ICONS2[f.cat]||'🍽️'}</div>
      <div style="flex:1"><div class="dse-name">${esc(f.name)}</div><div class="dse-meta">${f.cat||''}${f.qty?' · '+esc(f.qty):''}</div></div>
      <div class="dse-kcal">${Math.round(f.cal||0)} kcal</div>
    </div>`).join(''):'<div class="ds-empty">Sin comidas</div>';

  const actsHtml=day.activities.length?day.activities.map(a=>`
    <div class="ds-entry">
      <div class="dse-icon" style="background:rgba(255,149,0,0.12);font-size:16px">${a.icon||'🏃'}</div>
      <div style="flex:1"><div class="dse-name">${esc(a.name)}</div><div class="dse-meta">${a.dur?a.dur+' min':''}</div></div>
      <div class="dse-kcal" style="color:var(--accent3)">${a.kcal?'−'+Math.round(a.kcal)+' kcal':''}</div>
    </div>`).join(''):'<div class="ds-empty">Sin actividad</div>';

  pane.innerHTML=`
    <div class="detail-left">
      <div class="detail-header">
        <div class="dh-macros">
          <div class="dh-macro"><div class="dm-val" style="color:#FF5A52">${totCal}</div><div class="dm-lbl">kcal</div></div>
          <div class="dh-macro"><div class="dm-val" style="color:var(--accent)">${totProt}g</div><div class="dm-lbl">proteína</div></div>
          <div class="dh-macro"><div class="dm-val" style="color:var(--accent3)">${totCarb}g</div><div class="dm-lbl">carbos</div></div>
          <div class="dh-macro"><div class="dm-val" style="color:var(--text2)">${totFat}g</div><div class="dm-lbl">grasa</div></div>
        </div>
        <div style="margin-top:12px;display:flex;align-items:center;justify-content:space-between">
          <span style="font-size:12px;color:var(--text3)">Balance neto del día</span>
          <span class="balance-chip ${balChip}" style="font-size:13px">${balStr} kcal</span>
        </div>
      </div>
      <div class="detail-section">
        <div class="ds-head">Comidas</div>
        ${foodsHtml}
      </div>
      <div class="detail-section">
        <div class="ds-head">Actividad · −${totAct} kcal</div>
        ${actsHtml}
      </div>
    </div>`;
}

// ─── WEEK VIEW ───
function renderWeekView(){
  const today=new Date();
  const DN=['D','L','M','X','J','V','S'];
  const row=document.getElementById('week-bar-row');
  row.innerHTML='';
  const weekDays=[];
  for(let i=6;i>=0;i--){const dt=new Date(today);dt.setDate(today.getDate()-i);weekDays.push(dt.toISOString().slice(0,10))}
  weekDays.forEach(ds=>{
    const dt=new Date(ds+'T12:00:00');
    const hasData=S.days[ds]&&(S.days[ds].foods.length||S.days[ds].activities.length);
    const isSel=ds===selectedDate;
    const el=document.createElement('div');
    el.className='wb-day'+(hasData?' has':'')+(isSel?' sel':'');
    el.innerHTML=`<div class="wb-n">${DN[dt.getDay()]}</div><div class="wb-d">${dt.getDate()}</div><div class="wb-dot"></div>`;
    el.onclick=()=>{selectedDate=ds;renderCalendar();renderWeekView();renderDayDetail(ds)};
    row.appendChild(el);
  });
  const calData=weekDays.map(ds=>{const d=S.days[ds];return d?Math.round(d.foods.reduce((s,f)=>s+Number(f.cal||0),0)):null});
  const protData=weekDays.map(ds=>{const d=S.days[ds];return d?Math.round(d.foods.reduce((s,f)=>s+Number(f.prot||0),0)):null});
  const labels=weekDays.map(ds=>{const dt=new Date(ds+'T12:00:00');return DN[dt.getDay()]+' '+dt.getDate()});
  const goalCal=calcGoalCal(S.profile)||2000;
  const goalProt=calcGoalProt(S.profile)||150;
  buildChart('chart-cal',labels,calData,goalCal,'rgba(186,255,57,0.8)','chartCalW');
  buildChart('chart-prot',labels,protData,goalProt,'rgba(90,200,250,0.7)','chartProtW');
  // stats
  const dCount=weekDays.filter(ds=>S.days[ds]&&S.days[ds].foods.length).length;
  const calSum=weekDays.reduce((s,ds)=>s+(S.days[ds]?S.days[ds].foods.reduce((a,f)=>a+Number(f.cal||0),0):0),0);
  const protSum=weekDays.reduce((s,ds)=>s+(S.days[ds]?S.days[ds].foods.reduce((a,f)=>a+Number(f.prot||0),0):0),0);
  const actSum=weekDays.reduce((s,ds)=>s+(S.days[ds]?S.days[ds].activities.reduce((a,ac)=>a+Number(ac.kcal||0),0):0),0);
  document.getElementById('avg-cal').innerHTML=(dCount?Math.round(calSum/dCount):'—')+'<span class="stat-unit">kcal</span>';
  document.getElementById('avg-prot').innerHTML=(dCount?Math.round(protSum/dCount):'—')+'<span class="stat-unit">g</span>';
  document.getElementById('days-count').textContent=Object.keys(S.days).length;
  document.getElementById('total-act').innerHTML=Math.round(actSum)+'<span class="stat-unit">kcal</span>';
}

// ─── MONTH VIEW ───
function renderMonthView(){
  const y=calViewDate.getFullYear(),m=calViewDate.getMonth();
  const daysInMonth=new Date(y,m+1,0).getDate();
  const days=[];
  for(let d=1;d<=daysInMonth;d++)days.push(y+'-'+String(m+1).padStart(2,'0')+'-'+String(d).padStart(2,'0'));
  const calData=days.map(ds=>{const d=S.days[ds];return d&&d.foods.length?Math.round(d.foods.reduce((s,f)=>s+Number(f.cal||0),0)):null});
  const protData=days.map(ds=>{const d=S.days[ds];return d&&d.foods.length?Math.round(d.foods.reduce((s,f)=>s+Number(f.prot||0),0)):null});
  const labels=days.map(ds=>new Date(ds+'T12:00:00').getDate()+'');
  const goalCal=calcGoalCal(S.profile)||2000;
  const goalProt=calcGoalProt(S.profile)||150;
  buildChart('chart-cal-month',labels,calData,goalCal,'rgba(186,255,57,0.7)','chartCalM',true);
  buildChart('chart-prot-month',labels,protData,goalProt,'rgba(90,200,250,0.6)','chartProtM',true);
  const dCount=days.filter(ds=>S.days[ds]&&S.days[ds].foods.length).length;
  const calSum=days.reduce((s,ds)=>s+(S.days[ds]?S.days[ds].foods.reduce((a,f)=>a+Number(f.cal||0),0):0),0);
  const protSum=days.reduce((s,ds)=>s+(S.days[ds]?S.days[ds].foods.reduce((a,f)=>a+Number(f.prot||0),0):0),0);
  const actSum=days.reduce((s,ds)=>s+(S.days[ds]?S.days[ds].activities.reduce((a,ac)=>a+Number(ac.kcal||0),0):0),0);
  document.getElementById('mavg-cal').innerHTML=(dCount?Math.round(calSum/dCount):'—')+'<span class="stat-unit">kcal</span>';
  document.getElementById('mavg-prot').innerHTML=(dCount?Math.round(protSum/dCount):'—')+'<span class="stat-unit">g</span>';
  document.getElementById('mdays').textContent=dCount;
  document.getElementById('mact').innerHTML=Math.round(actSum)+'<span class="stat-unit">kcal</span>';
}

// ─── CHART BUILDER ───
function buildChart(canvasId,labels,data,goal,color,instKey,thin){
  const ctx=document.getElementById(canvasId);
  if(!ctx)return;
  if(window[instKey])window[instKey].destroy();
  window[instKey]=new Chart(ctx,{
    type:'bar',
    data:{
      labels,
      datasets:[
        {type:'bar',data,backgroundColor:color,borderRadius:6,borderSkipped:false,maxBarThickness:thin?14:28},
        {type:'line',data:Array(labels.length).fill(goal),borderColor:'rgba(186,255,57,0.4)',borderWidth:1.5,borderDash:[4,4],pointRadius:0,fill:false,tension:0}
      ]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>ctx.raw!==null?ctx.raw+(canvasId.includes('prot')?' g':' kcal'):'Sin datos'}}},
      scales:{
        x:{grid:{display:false},ticks:{font:{size:thin?9:11},color:'rgba(255,255,255,0.3)',maxRotation:0,maxTicksLimit:thin?10:7}},
        y:{grid:{color:'rgba(255,255,255,0.06)'},ticks:{font:{size:11},color:'rgba(255,255,255,0.3)'},beginAtZero:true}
      }
    }
  });
}

// ─── RENDER HISTORIAL (called when tab opens) ───
function renderHistorial(){
  calViewDate=new Date();
  selectedDate=todayStr();
  renderCalendar();
  renderDayDetail(selectedDate);
}

// ─── EXPORT ───
function exportData(){
  const blob=new Blob([JSON.stringify(S,null,2)],{type:'application/json'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='personaltrack_data.json';a.click();
}

